# ===============================================
# EDUSYS PRO - Environment Configuration
# ===============================================
# Copy this file to .env and fill in the values
# Required for deployment on Coolify
# ===============================================

# ===============================================
# SUPABASE (REQUIRED)
# ===============================================
# Get from your Supabase project dashboard:
# Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ===============================================
# SECURITY (REQUIRED)
# ===============================================
# Generate a strong random string (at least 32 characters)
# Use: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=30

# ===============================================
# SERVER
# ===============================================
SERVER_PORT=8080
WEB_PORT=3000
NODE_ENV=production

# ===============================================
# GOOGLE AUTHENTICATOR (2FA - Optional)
# ===============================================
# Not required for Supabase - uses Supabase Auth

# ===============================================
# PAYMENT GATEWAY (Optional)
# ===============================================
# For Indonesia payments (Midtrans/Xendit)
# MIDTRANS_CLIENT_KEY=
# MIDTRANS_SERVER_KEY=
# XENDIT_API_KEY=

# ===============================================
# EMAIL (Optional)
# ===============================================
# Supabase Auth handles password reset emails automatically
# For custom emails, configure in Supabase Dashboard > Authentication > SMTP
# SMTP_HOST=smtp.postmarkapp.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ===============================================
# WHATSAPP (Optional)
# ===============================================
# WHATSAPP_BUSINESS_ACCOUNT_ID=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_API_TOKEN=