# ===============================================
# EDUSYS PRO - Environment Configuration
# ===============================================
# Copy this file to .env and fill in values
# ===============================================

# ===============================================
# CONVEX (REQUIRED)
# ===============================================
# Auto-set by `npx convex dev` for local dev
# For production, get from Convex Dashboard > Settings > URL
VITE_CONVEX_URL=https://your-project.convex.cloud

# ===============================================
# GOOGLE AUTH (Optional)
# ===============================================
# Configure in Convex Dashboard > Auth > Google
VITE_GOOGLE_CLIENT_ID=

# ===============================================
# PAYMENT GATEWAY (Optional - Indonesia)
# ===============================================
# MIDTRANS_CLIENT_KEY=
# MIDTRANS_SERVER_KEY=
# XENDIT_API_KEY=

# ===============================================
# DEPLOYMENT
# ===============================================
NODE_ENV=production
WEB_PORT=3000