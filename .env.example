# ===============================================
# EDUSYS PRO - Environment Configuration
# ===============================================

# ===============================================
# SUPABASE (Database & Auth)
# ===============================================
# Get these from your Supabase project dashboard
# Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ===============================================
# GOOGLE AUTHENTICATOR (2FA)
# ===============================================
# JWT Secret for signing tokens (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=30

# ===============================================
# SERVER CONFIGURATION
# ===============================================
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
NODE_ENV=development
DEBUG=true

# ===============================================
# REDIS (Session Cache)
# ===============================================
# Optional - for session caching
REDIS_URL=redis://localhost:6379

# ===============================================
# GOOGLE AUTH (OAuth)
# ===============================================
# Get from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client IDs for your web application
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# ===============================================
# EMAIL (SMTP)
# ===============================================
# For sending emails (password reset, notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=Edusys Pro <noreply@school.edu>
SMTP_SECURE=false

# Alternative: Use Supabase Auth SMTP (in Supabase dashboard > Authentication > SMTP Configuration)
SMTP_CONFIG_ENABLED=false

# ===============================================
# PAYMENT GATEWAY (Indonesia)
# ===============================================
# Midtrans - https://midtrans.com
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_ENV=sandbox

# Xendit - https://xendit.co
XENDIT_API_KEY=your-xendit-api-key
XENDIT_ENV=sandbox

# ===============================================
# WHATSAPP BUSINESS API
# ===============================================
# For sending notifications via WhatsApp
# Get from: https://business.whatsapp.com/developers/developer-hub
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_API_TOKEN=your-permanent-access-token
WHATSAPP_API_URL=https://graph.facebook.com/v18.0

# ===============================================
# FILE STORAGE (S3/MinIO)
# ===============================================
# For storing files (documents, images, etc.)
# If using Supabase Storage, leave these empty
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=edusys
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_REGION=ap-southeast-1
S3_USE_SSL=false

# ===============================================
# CORS & SECURITY
# ===============================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-domain.com
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ===============================================
# APPLICATION SETTINGS
# ===============================================
DEFAULT_TIMEZONE=Asia/Jakarta
DEFAULT_CURRENCY=IDR
DEFAULT_LANGUAGE=en
SCHOOL_NAME=Edusys Pro Academy
SCHOOL_CODE=EDU001

# ===============================================
# FEATURES
# ===============================================
ENABLE_2FA=true
ENABLE_GOOGLE_AUTH=true
ENABLE_PAYMENT_GATEWAY=true
ENABLE_WHATSAPP=true
ENABLE_AI_FEATURES=false

# ===============================================
# LOGGING
# ===============================================
LOG_LEVEL=info
LOG_FORMAT=json